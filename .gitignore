# =============================================================================
# DVF+ Analytics — .gitignore
# =============================================================================

# =============================================================================
# Python bytecode and compiled files
# =============================================================================
__pycache__/
*.py[codz]
*$py.class
*.so

# =============================================================================
# Python packaging and distribution
# =============================================================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# =============================================================================
# Python package manager lock files (not used — uv manages deps via requirements.txt)
# =============================================================================
#Pipfile.lock
#uv.lock
#poetry.lock
#poetry.toml
#pdm.lock
#pdm.toml
.pdm-python
.pdm-build/
#pixi.lock
.pixi
__pypackages__/

# =============================================================================
# Test and coverage reports
# =============================================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# =============================================================================
# Installer and build logs
# =============================================================================
pip-log.txt
pip-delete-this-directory.txt
*.log

# =============================================================================
# Virtual environments and env files (secrets — never commit)
# =============================================================================
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# =============================================================================
# Translations
# =============================================================================
*.mo
*.pot

# =============================================================================
# Documentation build output
# =============================================================================
docs/_build/
/site

# =============================================================================
# Jupyter / IPython
# =============================================================================
.ipynb_checkpoints
profile_default/
ipython_config.py

# =============================================================================
# Type checkers and static analyzers
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# =============================================================================
# Linters and formatters
# =============================================================================
.ruff_cache/

# =============================================================================
# IDE and editor settings
# =============================================================================
# PyCharm / JetBrains
#.idea/
# Visual Studio Code
# .vscode/
# Spyder
.spyderproject
.spyproject
# Rope
.ropeproject
# Cursor
.cursorignore
.cursorindexingignore

# =============================================================================
# Framework-specific (not used in this project, kept from Python template)
# =============================================================================
# Django
local_settings.py
db.sqlite3
db.sqlite3-journal
# Flask
instance/
.webassets-cache
# Scrapy
.scrapy
# PyBuilder
.pybuilder/
target/
# Celery
celerybeat-schedule
celerybeat.pid
# SageMath
*.sage.py
# Abstra
.abstra/
# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/
# PyPI
.pypirc

# =============================================================================
# PROJECT-SPECIFIC: Agent framework (local workflow files, not tracked)
# =============================================================================
.claude/
CLAUDE.md
AGENTS_USAGE.md
PLAN.md
STATE.md
CORRECTIONS.md
REPORTS/

# =============================================================================
# PROJECT-SPECIFIC: GCP credentials (secrets — never commit)
# =============================================================================
gcp-sa-key.json

# =============================================================================
# PROJECT-SPECIFIC: Tests (generated by audit agents, not tracked)
# =============================================================================
tests/

# =============================================================================
# PROJECT-SPECIFIC: Terraform state and provider cache
# =============================================================================
# Downloaded provider binaries
terraform/.terraform/
# Current infrastructure state (contains secrets)
terraform/*.tfstate
# Previous state backup
terraform/*.tfstate.backup
# Provider version lock (regenerated by terraform init)
terraform/.terraform.lock.hcl

# =============================================================================
# PROJECT-SPECIFIC: Data files (large, downloaded at runtime by ingestion scripts)
# =============================================================================
# DVF+ SQL dumps, exported CSVs, GeoJSON files
data/
# Compressed SQL dumps
*.sql.gz
# GeoPackage files
*.gpkg

# =============================================================================
# PROJECT-SPECIFIC: dbt build artifacts (regenerated by dbt run)
# =============================================================================
# Compiled SQL and run results
dbt_dvf/target/
# Downloaded dbt packages (dbt_utils)
dbt_dvf/dbt_packages/
# dbt execution logs
dbt_dvf/logs/

# =============================================================================
# PROJECT-SPECIFIC: Local automation scripts (not part of the deliverable)
# =============================================================================
auto-cycle.sh
auto-cycle-2.sh