# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west9
GCS_BUCKET_NAME=your-project-id-dvf-data-lake
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa-key.json

# BigQuery Datasets
BQ_DATASET_RAW=dvf_raw
BQ_DATASET_STAGING=dvf_staging
BQ_DATASET_ANALYTICS=dvf_analytics

# PostgreSQL (ephemeral container -- local only)
POSTGRES_USER=dvf
POSTGRES_PASSWORD=dvf_local_only
POSTGRES_DB=dvf
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Pipeline Mode: demo (1-2 depts, ~10min) or full (all France, ~2h)
DVF_MODE=demo
DVF_DEMO_DEPARTMENTS=75,13

# Kestra
KESTRA_PORT=8080

# dbt
DBT_PROFILES_DIR=./dbt_dvf
