# =============================================================================
# DVF+ Analytics — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your GCP project details:
#   cp .env.example .env
#
# The only values you MUST change are GCP_PROJECT_ID and GCS_BUCKET_NAME.
# Everything else has sensible defaults for the demo.
#
# This file is loaded by:
#   - Makefile (via -include .env)
#   - Docker Compose (${VAR:-default} syntax)
#   - Python scripts (via python-dotenv)
#   - dbt (via env_var() in profiles.yml)
#
# IMPORTANT: Do NOT use inline comments (VAR=value # comment).
# Docker Compose treats everything after = as the value, including # comments.
# =============================================================================

# ---------------------------------------------------------------------------
# GCP Configuration (REQUIRED — change these)
# ---------------------------------------------------------------------------

# Your GCP project ID (find it at https://console.cloud.google.com/)
# This must match the project where Terraform created the resources.
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket name for the data lake (must be globally unique across all GCP)
# Convention: <project-id>-dvf-data-lake
GCS_BUCKET_NAME=your-project-id-dvf-data-lake

# Path to your GCP service account JSON key file.
# Download from: GCP Console > IAM > Service Accounts > dvf-pipeline > Keys
# Place the file at the project root as gcp-sa-key.json (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa-key.json

# GCP region for all resources. europe-west9 = Paris datacenter.
GCP_REGION=europe-west9

# ---------------------------------------------------------------------------
# BigQuery Datasets (defaults are fine — no need to change)
# ---------------------------------------------------------------------------
# These must match the dataset IDs in terraform/variables.tf.

# Raw tables loaded from GCS CSV files
BQ_DATASET_RAW=dvf_raw
# dbt staging views (cleaned source tables)
BQ_DATASET_STAGING=dvf_staging
# dbt mart tables (Kimball star schema)
BQ_DATASET_ANALYTICS=dvf_analytics

# ---------------------------------------------------------------------------
# PostgreSQL — ephemeral container, local only (defaults are fine)
# ---------------------------------------------------------------------------
# These credentials are used only for the local Docker container.
# The container has no persistent volume and is destroyed after CSV export.
# Do NOT use these credentials for any real database.

# Database superuser name
POSTGRES_USER=dvf
# Local-only password (not a secret)
POSTGRES_PASSWORD=dvf_local_only
# Database name for DVF+ data
POSTGRES_DB=dvf
# Host from the perspective of ingestion scripts
POSTGRES_HOST=localhost
# Exposed port (bound to 127.0.0.1 in docker-compose)
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Pipeline Mode
# ---------------------------------------------------------------------------
# Controls how much data the pipeline processes.
# demo = fast (~5 min), loads only the departments listed below
# full = all of France (~1-2 hours, requires National dump from Cerema)
DVF_MODE=demo

# Number of department SQL files to restore per chunk in full mode.
# Lower = less RAM but slower (more PostgreSQL resets).
# Higher = faster but more RAM usage.
# Default 10 produces ~10 chunks for full France, ~6 GB RAM per chunk.
DVF_CHUNK_SIZE=10

# Which departments to keep in demo mode (comma-separated, no spaces).
# Must match the region you downloaded from Cerema Box:
#   974       -> La Reunion (R04, ~38 MB, fastest for review)
#   75        -> Paris only (R11 Ile-de-France, ~700 MB)
#   75,77,78  -> Multiple Ile-de-France departments
DVF_DEMO_DEPARTMENTS=974

# ---------------------------------------------------------------------------
# Kestra Orchestration (optional — defaults are fine)
# ---------------------------------------------------------------------------
# Only needed if running the pipeline via Kestra (make docker-up-kestra).
# For local sequential mode (make run), Kestra is not required.

# Web UI and API port (http://localhost:8080)
KESTRA_PORT=8080
# Kestra's internal PostgreSQL user
KESTRA_DB_USER=kestra
# Kestra's internal PostgreSQL password
KESTRA_DB_PASSWORD=kestra_local_only
# Kestra's internal PostgreSQL database
KESTRA_DB_NAME=kestra

# ---------------------------------------------------------------------------
# dbt Configuration (defaults are fine)
# ---------------------------------------------------------------------------
# Points dbt to the profiles.yml file inside the dbt project directory.
# profiles.yml reads GCP credentials and dataset names from env vars above.
DBT_PROFILES_DIR=./dbt_dvf
